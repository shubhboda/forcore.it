VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role — server only (payments API). Never expose in the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Razorpay — use Test Mode keys first (rzp_test_...). Live: rzp_live_...
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Payments API (optional)
PAYMENT_SERVER_PORT=3001
# Comma-separated extra CORS origins for production, e.g. https://forcore.it
PAYMENT_ALLOWED_ORIGINS=

# Frontend: leave empty in dev (Vite proxies /api → localhost:3001). In prod, set if API is on another host.
VITE_PAYMENT_API_BASE=
VITE_PAYMENT_DEFAULT_INR=499
VITE_PAYMENT_DEFAULT_USD=6
